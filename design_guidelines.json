{
  "brand": {
    "name": "FrameFlow Studio",
    "tagline": "Your AI Creative Sidekick",
    "tone": "Playful, Intelligent, Efficient, Encouraging",
    "mascot": {
      "name": "Framey",
      "description": "A floating 3D-style abstract shape or robot that reacts to user actions.",
      "implementation": "Use a Lucide 'Bot' icon with a bouncing animation for MVP, or a simple CSS animated blob."
    }
  },
  "typography": {
    "font_family": {
      "headings": "Outfit, sans-serif",
      "body": "DM Sans, sans-serif",
      "mono": "JetBrains Mono, monospace"
    },
    "scale": {
      "h1": "text-5xl md:text-7xl font-bold tracking-tight",
      "h2": "text-4xl md:text-5xl font-semibold tracking-tight",
      "h3": "text-2xl md:text-3xl font-semibold",
      "body_lg": "text-lg leading-relaxed",
      "body_base": "text-base leading-relaxed",
      "caption": "text-sm font-medium text-muted-foreground uppercase tracking-widest"
    }
  },
  "colors": {
    "theme": "hybrid",
    "mode_default": "light",
    "palette": {
      "primary": {
        "base": "bg-indigo-600",
        "hover": "hover:bg-indigo-700",
        "text": "text-indigo-600",
        "foreground": "text-white"
      },
      "secondary": {
        "base": "bg-orange-500",
        "text": "text-orange-500",
        "foreground": "text-white"
      },
      "accent": {
        "base": "bg-pink-500",
        "gradient": "from-indigo-500 via-purple-500 to-pink-500"
      },
      "background": {
        "main": "bg-slate-50",
        "card": "bg-white",
        "sidebar": "bg-white/80 backdrop-blur-xl"
      },
      "text": {
        "main": "text-slate-900",
        "muted": "text-slate-500",
        "inverted": "text-white"
      }
    },
    "gradients": {
      "hero": "bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500",
      "subtle": "bg-gradient-to-br from-indigo-50 to-white"
    }
  },
  "layout_strategy": {
    "dashboard": {
      "type": "bento_grid",
      "grid_cols": "grid-cols-1 md:grid-cols-4 lg:grid-cols-6",
      "gap": "gap-6",
      "padding": "p-6 md:p-8",
      "widgets": {
        "hero_stats": "col-span-full md:col-span-4 lg:col-span-4 row-span-2",
        "quick_action": "col-span-1 md:col-span-2 lg:col-span-2 row-span-1",
        "recent_list": "col-span-full md:col-span-3 lg:col-span-3 row-span-2"
      }
    },
    "editor": {
      "type": "three_pane",
      "structure": "flex h-screen overflow-hidden",
      "sidebar_left": "w-64 border-r bg-white/50 backdrop-blur-sm p-4 hidden md:flex flex-col gap-4",
      "canvas_area": "flex-1 bg-slate-100 flex items-center justify-center relative overflow-hidden",
      "sidebar_right": "w-80 border-l bg-white p-4 hidden lg:flex flex-col gap-6 overflow-y-auto"
    },
    "landing": {
      "type": "asymmetrical",
      "hero_section": "min-h-[90vh] flex items-center justify-center relative overflow-hidden",
      "grid_pattern": "absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"
    }
  },
  "components": {
    "buttons": {
      "primary": "rounded-full px-8 py-3 bg-indigo-600 text-white font-semibold shadow-lg shadow-indigo-500/25 hover:scale-105 transition-all duration-200 hover:shadow-indigo-500/40",
      "secondary": "rounded-full px-8 py-3 bg-white text-slate-900 border border-slate-200 font-medium hover:bg-slate-50 hover:border-slate-300 transition-all duration-200",
      "ghost": "rounded-lg px-4 py-2 text-slate-600 hover:bg-slate-100 hover:text-slate-900 font-medium transition-colors"
    },
    "cards": {
      "base": "bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow duration-300 p-6",
      "interactive": "cursor-pointer hover:border-indigo-200 hover:shadow-xl hover:shadow-indigo-500/10 group"
    },
    "inputs": {
      "base": "rounded-xl border-slate-200 bg-slate-50/50 px-4 py-3 text-base focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all",
      "label": "text-sm font-semibold text-slate-700 mb-2 block"
    }
  },
  "visual_enhancers": {
    "radius": {
      "default": "rounded-xl",
      "large": "rounded-2xl",
      "full": "rounded-full"
    },
    "shadows": {
      "soft": "shadow-[0_8px_30px_rgb(0,0,0,0.04)]",
      "glow": "shadow-[0_0_50px_-12px_rgb(99,102,241,0.25)]"
    },
    "glassmorphism": {
      "heavy": "bg-white/70 backdrop-blur-xl border border-white/20 shadow-lg",
      "light": "bg-white/40 backdrop-blur-md border border-white/10"
    }
  },
  "motion": {
    "default_transition": "transition-all duration-300 ease-out",
    "hover_lift": "hover:-translate-y-1",
    "micro_interactions": {
      "button_click": "active:scale-95",
      "card_hover": "hover:scale-[1.02]"
    }
  },
  "image_urls": {
    "mascot_reference": "https://images.unsplash.com/photo-1746879669501-42659283201f?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjY2NzV8MHwxfHNlYXJjaHwzfHwzZCUyMGN1dGUlMjByb2JvdCUyMG1hc2NvdCUyMG1pbmltYWwlMjB3aGl0ZSUyMGJhY2tncm91bmR8ZW58MHx8fHwxNzczMDYxNjg1fDA&ixlib=rb-4.1.0&q=85",
    "hero_background": "https://images.unsplash.com/photo-1762716514229-739f6769e282?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjA1MTN8MHwxfHNlYXJjaHwyfHxhYnN0cmFjdCUyMGdyYWRpZW50JTIwZ3JhaW4lMjB0ZXh0dXJlJTIwcHVycGxlJTIwb3JhbmdlfGVufDB8fHx8MTc3MzA2MTY4N3ww&ixlib=rb-4.1.0&q=85",
    "team_placeholder": "https://images.unsplash.com/photo-1758873269317-51888e824b28?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjY2NzZ8MHwxfHNlYXJjaHwzfHxjcmVhdGl2ZSUyMG1hcmtldGluZyUyMHRlYW0lMjB3b3JraW5nJTIwbW9kZXJuJTIwb2ZmaWNlJTIwZGl2ZXJzZXxlbnwwfHx8fDE3NzMwNjE2ODZ8MA&ixlib=rb-4.1.0&q=85",
    "content_example_cafe": "https://images.unsplash.com/photo-1764395025770-81edf84d57b3?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjA1NTZ8MHwxfHNlYXJjaHwxfHxjb2ZmZWUlMjBzaG9wJTIwYWVzdGhldGljJTIwbGF0dGUlMjBhcnQlMjBjb3p5fGVufDB8fHx8MTc3MzA2MTY4OHww&ixlib=rb-4.1.0&q=85"
  },
  "universal_guidelines": [
    "Do not use generic 'Inter' for headings. Use 'Outfit' via Google Fonts.",
    "Avoid solid black (#000000). Use Slate-900 (#0f172a).",
    "Every button hover must have a scale effect.",
    "Use generous padding (p-6 minimum) for cards.",
    "Dashboard should feel like a 'Creative Studio', not a spreadsheet.",
    "Implement 'Framey' the mascot in empty states.",
    "Use the gradient texture provided in 'hero_background' for the 'AI Generation' loading states.",
    "Ensure high contrast for text (APCA standard).",
    "Use 'sonner' for all notifications.",
    "All interactive elements must have 'data-testid'."
  ]
}